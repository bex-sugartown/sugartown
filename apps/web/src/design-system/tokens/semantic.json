{
  "color": {
    "brand": {
      "primary":   "{color.pink.500}",
      "secondary": "{color.maroon.600}"
    },
    "bg": {
      "canvas":     "{color.white}",
      "surface":    "{color.white}",
      "surfaceAlt": "{color.softgrey.50}",
      "subtle":     "{color.softgrey.100}",
      "midnight":   "{color.midnight.900}",
      "secondary":  "{color.neutral.100}",
      "tertiary":   "{color.neutral.200}"
    },
    "text": {
      "default":   "{color.charcoal.900}",
      "primary":   "{color.charcoal.900}",
      "secondary": "{color.neutral.600}",
      "muted":     "{color.softgrey.400}",
      "brand":     "{color.maroon.600}"
    },
    "border": {
      "default": "rgba(13, 18, 38, 0.08)",
      "subtle":  "{color.softgrey.200}",
      "medium":  "{color.neutral.200}",
      "strong":  "{color.neutral.600}"
    },
    "accent": {
      "primary": "{color.pink.500}",
      "soft":    "rgba(255, 36, 125, 0.08)"
    },
    "link": {
      "default": "{color.brand.primary}",
      "hover":   "{color.brand.secondary}"
    },
    "focus":  "{color.pink.500}",
    "danger": "{color.maroon.600}"
  },
  "radius": {
    "button":  "{radius.xs}",
    "tag":     "{radius.xs}",
    "pill":    "{radius.xs}",
    "callout": "{radius.sm}",
    "code":    "{radius.sm}",
    "card":    "{radius.md}",
    "hero":    "{radius.xl}",
    "media":   "{radius.xl}",
    "full":    "{radius.full}"
  },
  "font": {
    "narrative": "{font.family.narrative}",
    "ui":        "{font.family.ui}",
    "mono":      "{font.family.mono}",
    "body":      "{font.size.md}",
    "caption":   "{font.size.xs}",
    "heading": {
      "1": "{font.size.display}",
      "2": "{font.size.2xl}",
      "3": "{font.size.xl}",
      "4": "{font.size.lg}"
    }
  },
  "spacing": {
    "stack": {
      "xs": "{space.1}",
      "sm": "{space.2}",
      "md": "{space.4}",
      "lg": "{space.6}",
      "xl": "{space.8}"
    },
    "inline": {
      "sm": "{space.2}",
      "md": "{space.3}",
      "lg": "{space.4}"
    },
    "inset": {
      "xs": "{space.1}",
      "sm": "{space.2}",
      "md": "{space.4}",
      "lg": "{space.6}"
    },
    "gutter": "{space.4}"
  },
  "shadow": {
    "card":      "{shadow.card}",
    "cardHover": "{shadow.cardHover}",
    "cardDeep":  "{shadow.cardDeep}",
    "sm":        "{shadow.sm}",
    "md":        "{shadow.md}",
    "lg":        "{shadow.lg}"
  }
}
